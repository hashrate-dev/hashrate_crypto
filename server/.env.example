# Puerto del servidor (opcional, por defecto 3001)
# PORT=3001

# --- Email: aviso al cambiar contraseña ---
# Si no configurás estas variables, el cambio de contraseña funciona igual pero no se envía email.

# Gmail: usar una "Contraseña de aplicación" (no tu contraseña normal).
# Creala en: Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-de-aplicacion

# Remitente que verá el usuario (opcional)
# EMAIL_FROM=Wallet <noreply@tudominio.com>

# Otros proveedores:
# Outlook/Hotmail: smtp.office365.com, puerto 587
# Yahoo: smtp.mail.yahoo.com, puerto 587
# Mailtrap (pruebas): smtp.mailtrap.io, usuario y contraseña de tu inbox

# --- Análisis de mercado por IA (opcional) ---
# Si no configurás OPENAI_API_KEY, en la ficha de cada activo se muestra un análisis local basado en datos.
# Con la clave, el comentario lo genera GPT (actualizado cada 10 min).
# OPENAI_API_KEY=sk-...
